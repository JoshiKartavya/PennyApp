<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☕ quick presets"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/btn_widget_preset_1"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="10dp">
        <TextView
            android:id="@+id/txt_widget_preset_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tea &amp; Chips (₹20)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_widget_preset_2"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="10dp">
        <TextView
            android:id="@+id/txt_widget_preset_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Metro Ride (₹40)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_widget_preset_3"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="10dp">
        <TextView
            android:id="@+id/txt_widget_preset_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Office Lunch (₹150)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>
</LinearLayout>
